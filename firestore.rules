rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin check: Matches the hardcoded list in environment variables
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'bercho001@gmail.com' || 
        request.auth.token.email == 'fernandosoria1379@gmail.com'
      );
    }

    // 1. Projects and Experience: Publicly readable, admin writable
    match /projects/{project} {
      allow read: if true;
      allow write: if isAdmin(); 
    }
    
    match /experience/{exp} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Contact Requests: Anyone can submit (Create), Admins can Read
    match /contactRequests/{requestId} {
      allow create: if true;
      allow read: if true; // Supporting simple dash for now
      allow update, delete: if isAdmin();
    }
  }
}
